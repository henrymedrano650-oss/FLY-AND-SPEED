local function enableFly()
    cleanFly()
    if not RootPart or not Humanoid then return end
    Humanoid.PlatformStand = true
    flyBV = Instance.new("BodyVelocity")
    flyBV.Name = "NexoFlyVel"
    flyBV.MaxForce = Vector3.new(1e6,1e6,1e6)
    flyBV.Velocity = Vector3.zero
    flyBV.Parent = RootPart
    flyBG = Instance.new("BodyGyro")
    flyBG.Name = "NexoFlyGyro"
    flyBG.MaxTorque = Vector3.new(1e6,1e6,1e6)
    flyBG.P = 5000
    flyBG.D = 100
    flyBG.CFrame = RootPart.CFrame
    flyBG.Parent = RootPart
    if isMobile then createMobileFlyButtons() end
    flyConn = RunService.Heartbeat:Connect(function()
        if not flyEnabled then return end
        if not RootPart or not RootPart.Parent then return end
        if not flyBV or not flyBV.Parent then return end
        if not flyBG or not flyBG.Parent then return end
        local cam = workspace.CurrentCamera
        local dir = Vector3.zero
        if isMobile then
            local md = Humanoid.MoveDirection
            if md.Magnitude > 0 then dir = dir + Vector3.new(md.X,0,md.Z) end
            if flyUpHeld then dir = dir + Vector3.new(0,1,0) end
            if flyDownHeld then dir = dir + Vector3.new(0,-1,0) end
        else
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then dir = dir + cam.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then dir = dir - cam.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then dir = dir - cam.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then dir = dir + cam.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then dir = dir + Vector3.new(0,1,0) end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then dir = dir + Vector3.new(0,-1,0) end
        end
        flyBV.Velocity = dir.Magnitude > 0 and dir.Unit * flySpeed or Vector3.zero
        flyBG.CFrame = cam.CFrame
    end)
end

local function disableFly()
    flyEnabled = false
    cleanFly()
    removeMobileFlyButtons()
    if Humanoid then Humanoid.PlatformStand = false end
end

-- ========== CLONE ==========
local function spawnClone(targetName)
    local target = nil
    if targetName and targetName ~= "" then
        for _, p in pairs(Players:GetPlayers()) do
            if p.Name:lower():find(targetName:lower(), 1, true) then target = p; break end
        end
        if not target then return nil, "notfound" end
    end
    local sourceChar = target and target.Character or Character
    if not sourceChar then return nil, "nochar" end
    local clone = sourceChar:Clone()
    clone.Name = (target and target.Name or LocalPlayer.Name) .. "_Clone"
    for _, v in pairs(clone:GetDescendants()) do
        if v:IsA("Script") or v:IsA("LocalScript") or v:IsA("ModuleScript") then v:Destroy() end
    end
    local anim = clone:FindFirstChild("Animate")
    if anim then anim:Destroy() end
    local sr = sourceChar:FindFirstChild("HumanoidRootPart")
    if sr then clone:SetPrimaryPartCFrame(sr.CFrame * CFrame.new(4,0,0)) end
    clone.Parent = workspace
    table.insert(clones, clone)
    return clone, "ok"
end

local function removeAllClones()
    for _, c in pairs(clones) do if c and c.Parent then c:Destroy() end end
    clones = {}
end

-- ========== FPS BOOST ==========
local origLighting = {}

local function applyFPS()
    origLighting = {
        GlobalShadows = Lighting.GlobalShadows,
        FogEnd = Lighting.FogEnd,
        Brightness = Lighting.Brightness,
        Ambient = Lighting.Ambient,
        OutdoorAmbient = Lighting.OutdoorAmbient,
    }
    Lighting.GlobalShadows = false
    Lighting.FogEnd = 100000
    Lighting.Brightness = 1
    Lighting.Ambient = Color3.fromRGB(128,128,128)
    Lighting.OutdoorAmbient = Color3.fromRGB(128,128,128)
    for _, v in pairs(Lighting:GetChildren()) do
        pcall(function()
            if v:IsA("PostEffect") or v:IsA("Atmosphere") then v.Enabled = false end
        end)
    end
    for _, v in pairs(workspace:GetDescendants()) do
        pcall(function()
            if v:IsA("ParticleEmitter") or v:IsA("Fire") or v:IsA("Smoke") or
               v:IsA("Sparkles") or v:IsA("Beam") or v:IsA("Trail") then v.Enabled = false end
        end)
    end
    pcall(function() settings().Rendering.QualityLevel = Enum.QualityLevel.Level01 end)
end

local function removeFPS()
    for k, v in pairs(origLighting) do Lighting[k] = v end
    for _, v in pairs(Lighting:GetChildren()) do
        pcall(function()
            if v:IsA("PostEffect") or v:IsA("Atmosphere") then v.Enabled = true end
        end)
    end
    for _, v in pairs(workspace:GetDescendants()) do
        pcall(function()
            if v:IsA("ParticleEmitter") or v:IsA("Fire") or v:IsA("Smoke") or
               v:IsA("Sparkles") or v:IsA("Beam") or v:IsA("Trail") then v.Enabled = true end
        end)
    end
    pcall(function() settings().Rendering.QualityLevel = Enum.QualityLevel.Automatic end)
end

