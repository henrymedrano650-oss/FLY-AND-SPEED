-- ========== STAT ENFORCER ==========
local function startStatLoop()
    if statLoop then statLoop:Disconnect() end
    statLoop = RunService.Heartbeat:Connect(function()
        if not Humanoid or not Humanoid.Parent then return end
        if Humanoid.WalkSpeed ~= currentWalkSpeed then
            Humanoid.WalkSpeed = currentWalkSpeed
        end
        if Humanoid.UseJumpPower then
            if Humanoid.JumpPower ~= currentJumpPower then
                Humanoid.JumpPower = currentJumpPower
            end
        else
            local jh = (currentJumpPower * currentJumpPower) / (2 * workspace.Gravity)
            if math.abs(Humanoid.JumpHeight - jh) > 0.1 then
                Humanoid.JumpHeight = jh
            end
        end
    end)
end
startStatLoop()

-- ========== NOCLIP ==========
local PARTS = {
    "HumanoidRootPart","UpperTorso","LowerTorso","Head",
    "LeftUpperArm","LeftLowerArm","LeftHand",
    "RightUpperArm","RightLowerArm","RightHand",
    "LeftUpperLeg","LeftLowerLeg","LeftFoot",
    "RightUpperLeg","RightLowerLeg","RightFoot",
    "Torso","Left Arm","Right Arm","Left Leg","Right Leg",
}

local function enableNoclip()
    if noclipConn then noclipConn:Disconnect() end
    origCollision = {}
    if Character then
        for _, p in pairs(Character:GetDescendants()) do
            if p:IsA("BasePart") then
                origCollision[p] = p.CanCollide
                p.CanCollide = false
            end
        end
    end
    noclipConn = RunService.Stepped:Connect(function()
        if not noclipEnabled or not Character then return end
        for _, n in ipairs(PARTS) do
            local p = Character:FindFirstChild(n)
            if p and p:IsA("BasePart") then p.CanCollide = false end
        end
        for _, p in pairs(Character:GetDescendants()) do
            if p:IsA("BasePart") then p.CanCollide = false end
        end
    end)
end

local function disableNoclip()
    noclipEnabled = false
    if noclipConn then noclipConn:Disconnect() noclipConn = nil end
    if Character then
        for _, p in pairs(Character:GetDescendants()) do
            if p:IsA("BasePart") then
                p.CanCollide = origCollision[p] ~= nil and origCollision[p] or true
            end
        end
    end
    origCollision = {}
end

-- ========== INVISIBLE ==========
local function forceInvis(p)
    pcall(function()
        if p:IsA("BasePart") or p:IsA("Decal") or p:IsA("Texture") then
            if origTransparency[p] == nil then
                origTransparency[p] = p.Transparency
            end
            p.Transparency = 1
        end
    end)
end

local function applyInvisToChar()
    if not Character then return end
    for _, p in pairs(Character:GetDescendants()) do
        forceInvis(p)
    end
    local tool = Character:FindFirstChildOfClass("Tool")
    if tool then
        for _, p in pairs(tool:GetDescendants()) do forceInvis(p) end
    end
end

local function enableInvis()
    if invisConn then invisConn:Disconnect() invisConn = nil end
    if descendantConn then descendantConn:Disconnect() descendantConn = nil end
    origTransparency = {}
    applyInvisToChar()
    if Character then
        descendantConn = Character.DescendantAdded:Connect(function(p)
            if not invisEnabled then return end
            task.defer(function()
                if not invisEnabled then return end
                forceInvis(p)
            end)
        end)
    end
    invisConn = RunService.Heartbeat:Connect(function()
        if not invisEnabled or not Character or not Character.Parent then return end
        for _, p in pairs(Character:GetDescendants()) do
            if (p:IsA("BasePart") or p:IsA("Decal") or p:IsA("Texture")) and p.Transparency ~= 1 then
                p.Transparency = 1
            end
        end
        local tool = Character:FindFirstChildOfClass("Tool")
        if tool then
            for _, p in pairs(tool:GetDescendants()) do
                if (p:IsA("BasePart") or p:IsA("Decal")) and p.Transparency ~= 1 then
                    p.Transparency = 1
                end
            end
        end
    end)
end

local function disableInvis()
    invisEnabled = false
    if invisConn then invisConn:Disconnect() invisConn = nil end
    if descendantConn then descendantConn:Disconnect() descendantConn = nil end
    if not Character then origTransparency = {} return end
    for p, t in pairs(origTransparency) do
        pcall(function()
            if p and p.Parent then p.Transparency = t end
        end)
    end
    origTransparency = {}
end

local function refreshInvis()
    if not invisEnabled then return end
    for _, p in pairs(Character:GetDescendants()) do
        if (p:IsA("BasePart") or p:IsA("Decal") or p:IsA("Texture")) then
            if origTransparency[p] == nil then origTransparency[p] = p.Transparency end
            pcall(function() p.Transparency = 1 end)
        end
    end
end

-- ========== DRAGGABLE ==========
local function makeDraggable(btn, getLocked)
    local dragging = false
    local dragStart, startPos
    btn.InputBegan:Connect(function(input)
        if getLocked and getLocked() then return end
        if input.UserInputType == Enum.UserInputType.Touch or
           input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = btn.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if getLocked and getLocked() then dragging = false return end
        if dragging and (input.UserInputType == Enum.UserInputType.Touch or
           input.UserInputType == Enum.UserInputType.MouseMovement) then
            local delta = input.Position - dragStart
            btn.Position = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + delta.X,
                startPos.Y.Scale, startPos.Y.Offset + delta.Y
            )
        end
    end)
end

